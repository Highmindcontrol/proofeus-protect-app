    "expo-crypto": "~15.0.0",
    "expo-dev-client": "~6.0.0",
    "expo-file-system": "~19.0.0",
    "expo-font": "~14.0.0",
    "expo-linking": "~8.0.0",
    "expo-local-authentication": "~17.0.0",
